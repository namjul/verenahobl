---
interface Props {
  process?: string;
}
const { process } = Astro.props;
---

<div class="mt-12">
  <details class="group border-t border-base-300 pt-6">
    <summary class="tag cursor-pointer opacity-40 hover:opacity-80 transition-opacity duration-200 list-none flex items-center gap-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-base-content">
      <span>Entstehung</span>
      <svg
        class="w-3 h-3 transition-transform duration-200 group-open:rotate-180"
        viewBox="0 0 12 12"
        fill="none"
        aria-hidden="true"
      >
        <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </summary>
    <div class="mt-6 prose prose-sm max-w-none">
      {process
        ? <p style="white-space: pre-wrap">{process}</p>
        : <p class="opacity-40 text-sm">[Entstehungsgeschichte folgt — Skizzen, Prozessfotos und Beschreibung hier einfügen]</p>
      }
    </div>
  </details>
</div>
