---
const year = new Date().getFullYear();
---

<footer class="border-t border-base-300 mt-24 py-12">
  <div class="max-w-6xl mx-auto px-6 flex flex-col items-center gap-6 text-sm">

    <!-- Bottle mascot -->
    <img
      src="/assets/flasche.webp"
      alt=""
      role="presentation"
      class="h-14 w-auto opacity-80"
      width="56"
      height="56"
    />

    <!-- Copyright + legal -->
    <div class="flex flex-col sm:flex-row items-center gap-3 opacity-50 text-xs">
      <span>© {year} Verena Hobl</span>
      <span class="hidden sm:inline">·</span>
      <a
        href="/impressum"
        class="underline underline-offset-4 hover:opacity-60 transition-opacity duration-200"
      >
        Impressum | Datenschutz
      </a>
    </div>

  </div>
</footer>
